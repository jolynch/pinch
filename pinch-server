#!/bin/bash
set -euf -o pipefail

MUID=$(id -u)
DEBUG="${DEBUG:-no}"
PORT="${PORT:-2355}"
DIEAFTER="${DIEAFTER:-0s}"
ONESHOT="${ONESHOT:-false}"
PIPEDIR="${PIPEDIR:-/var/lib/pinch}"
DETACH="${DETACH:-true}"

if [[ "$(docker images -q jolynch/pinch-server:latest 2> /dev/null)" == "" ]]; then
    echo "Pulling pinch server docker image"
    docker pull jolynch/pinch-server
fi

if [ ! -d "/var/lib/pinch" ]; then
    echo "Creating /var/lib/pinch"
    sudo mkdir "/var/lib/pinch"
    echo "Chowning /var/lib/pinch to $(whoami)"
    sudo chown -R $MUID /var/lib/pinch
fi

mkdir -p "/var/lib/pinch/in"
mkdir -p "/var/lib/pinch/keys"
mkdir -p "/var/lib/pinch/out"

if [[ "${DETACH}" == "true" ]]; then
    DOCKER_RUN="docker run --rm -d -v /var/lib/pinch/:/var/lib/pinch -p 127.0.0.1:${PORT}:8080 --name pinch-server jolynch/pinch-server pinch-server -listen 0.0.0.0:8080 -die-after ${DIEAFTER}"
else
    DOCKER_RUN="docker run --rm -v /var/lib/pinch/:/var/lib/pinch -p 127.0.0.1:${PORT}:8080 --name pinch-server jolynch/pinch-server pinch-server -listen 0.0.0.0:8080 -die-after ${DIEAFTER}"
fi


if [[ ${DEBUG} != "no" ]]; then
    1>&2 echo "Running ${DOCKER_RUN}"
fi

exec $DOCKER_RUN $@
